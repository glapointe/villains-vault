# ─────────────────────────────────────────────
# ADMIN — DLS
# ─────────────────────────────────────────────

### Get All DLS Races (including past)
GET {{Falchion.Villains.Vault.Api_HostAddress}}/api/v1.0/admin/dls/races?upcomingOnly=false
Accept: application/json
Authorization: Bearer {{auth_token}}

### Create DLS Race
POST {{Falchion.Villains.Vault.Api_HostAddress}}/api/v1.0/admin/dls/races
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
	"name": "2026 WDW Marathon - Dead Last Start",
	"raceDate": "2026-01-11",
	"bibNumbers": "1001,1002,1003"
}

### Update DLS Race
PUT {{Falchion.Villains.Vault.Api_HostAddress}}/api/v1.0/admin/dls/races/1
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
	"name": "2026 WDW Marathon - Dead Last Start (Updated)",
	"raceDate": "2026-01-11"
}

### Delete DLS Race
DELETE {{Falchion.Villains.Vault.Api_HostAddress}}/api/v1.0/admin/dls/races/1
Authorization: Bearer {{auth_token}}

### Get Declarations for a DLS Race (Admin)
GET {{Falchion.Villains.Vault.Api_HostAddress}}/api/v1.0/admin/dls/races/1/declarations
Accept: application/json
Authorization: Bearer {{auth_token}}

### Update Declaration (Admin Override)
PUT {{Falchion.Villains.Vault.Api_HostAddress}}/api/v1.0/admin/dls/declarations/1
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
	"bibNumber": 9999
}

### Delete Declaration (Admin Override)
DELETE {{Falchion.Villains.Vault.Api_HostAddress}}/api/v1.0/admin/dls/declarations/1
Authorization: Bearer {{auth_token}}

### Process DLS Declarations after Race Scrape
POST {{Falchion.Villains.Vault.Api_HostAddress}}/api/v1.0/admin/dls/races/1/process/42
Accept: application/json
Authorization: Bearer {{auth_token}}

###
