{
  "name": "falchion.villains.vault",
  "version": "1.0.1",
  "main": "index.ts",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start",
    "start:clear": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start --clear",
    "android": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo run:android",
    "ios": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo run:ios",
    "web": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start --web",
    "web:clear": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start --web --clear",
    "build:web:prod": "npm run clear-cache && cross-env NODE_OPTIONS=--max-old-space-size=8192 ENV_NAME=prod NODE_ENV=production expo export --clear --platform web --output-dir ../api/Falchion.Villains.Vault.Api/wwwroot && npm run copy-assets",
    "build:web:stage": "npm run clear-cache && cross-env NODE_OPTIONS=--max-old-space-size=8192 ENV_NAME=stage NODE_ENV=production expo export --clear --platform web --output-dir ../api/Falchion.Villains.Vault.Api/wwwroot && npm run copy-assets",
    "copy-assets": "shx mkdir -p ../api/Falchion.Villains.Vault.Api/wwwroot/assets/images ../api/Falchion.Villains.Vault.Api/wwwroot/assets/content && shx cp -r assets/images/* ../api/Falchion.Villains.Vault.Api/wwwroot/assets/images/ && shx cp -r assets/content/* ../api/Falchion.Villains.Vault.Api/wwwroot/assets/content/",
    "clear-cache": "shx rm -rf .expo && shx rm -rf node_modules/.cache",
    "expo-prebuild": "expo prebuild --clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.11.0",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@fluentui/react-datepicker-compat": "^0.6.22",
    "@microsoft/react-native-clarity": "^4.5.3",
    "@openmeteo/sdk": "^1.25.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-picker/picker": "^2.11.4",
    "@shopify/react-native-skia": "^2.4.18",
    "@types/node": "^25.0.10",
    "@types/react-datepicker": "^6.2.0",
    "axios": "^1.13.3",
    "expo": "~54.0.32",
    "expo-clipboard": "^55.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "^6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "^6.0.22",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "^31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "jszip": "^3.10.1",
    "nativewind": "^4.2.1",
    "plotly.js": "^3.4.0",
    "plotly.js-gl2d-dist": "^3.4.0",
    "react": "19.1.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "react-native": "0.81.5",
    "react-native-auth0": "^5.4.0",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-pell-rich-editor": "^1.10.0",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.20.0",
    "react-native-svg": "^15.4.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.7.2",
    "react-plotly.js": "^2.6.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.4.19",
    "victory": "^37.3.6",
    "victory-native": "^41.20.2"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "@types/react-plotly.js": "^2.6.4",
    "babel-preset-expo": "^54.0.10",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.16",
    "react-native-svg-transformer": "^1.5.3",
    "shx": "^0.4.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "private": true
}
