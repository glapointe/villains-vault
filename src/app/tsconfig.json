{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "skipLibCheck": true,
        "strict": true,
        "baseUrl": ".",
        "module": "esnext",
        "moduleResolution": "node",
        "paths": {
            "@react-native-async-storage/async-storage": [
                "node_modules/@react-native-async-storage/async-storage/lib/typescript/index.d.ts"
            ]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts",
        "nativewind-env.d.ts"
    ]
}
